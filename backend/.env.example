# ══════════════════════════════════════════════════════════════
# superberater Backend — Environment Variables
# Copy to .env and fill in your values.
# ══════════════════════════════════════════════════════════════

# OpenRouter (required — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Supabase (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-anon-key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key

# App
BACKEND_URL=http://localhost:9000
FRONTEND_URL=http://localhost:3000

# Defaults (in DEMO_MODE=true, these are auto-overridden to free models)
DEFAULT_MODERATOR_MODEL=anthropic/claude-sonnet-4.6
DEFAULT_AGENT_MODEL=anthropic/claude-haiku-4.5
AGENT_TIMEOUT_SECONDS=60
MODERATOR_TIMEOUT_SECONDS=120

# Demo mode (optional, default: false)
# true  = Public demo: only free models by default, users enter own key for paid models
#         DEFAULT_MODERATOR_MODEL and DEFAULT_AGENT_MODEL are auto-overridden to free variants
# false = Self-hosted: all models available via .env key
DEMO_MODE=false
