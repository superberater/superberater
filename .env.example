# ══════════════════════════════════════════════════════════════
# CrewAI — Environment Variables
# Copy to backend/.env and fill in your values.
# The install.sh script does this automatically.
# ══════════════════════════════════════════════════════════════

# OpenRouter (required — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Supabase Cloud (option A — recommended)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Local PostgreSQL (option B — leave Supabase fields empty)
# DATABASE_URL=postgresql://crewai:password@localhost:5432/crewai

# App
BACKEND_URL=http://localhost:9000
FRONTEND_URL=http://localhost:3000

# Timeouts
DEFAULT_MODERATOR_MODEL=anthropic/claude-sonnet-4.6
DEFAULT_AGENT_MODEL=anthropic/claude-haiku-4.5
AGENT_TIMEOUT_SECONDS=60
MODERATOR_TIMEOUT_SECONDS=120
