# ══════════════════════════════════════════════════════════════
# superberater Frontend — Environment Variables
# Copy to .env.local and fill in your values.
# ══════════════════════════════════════════════════════════════

NEXT_PUBLIC_API_URL=http://localhost:9000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-anon-key

# Canonical URL for SEO (metadata, sitemap.xml, robots.txt). Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Search Console HTML tag verification (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-string
